# Window Aesthetics
title = " "
macos-window-shadow = true
macos-titlebar-proxy-icon = hidden
window-save-state = never

window-padding-x = 3
window-padding-y = 3
window-padding-balance = true

# Behavior & Shell
shell-integration = detect
confirm-close-surface = false
macos-option-as-alt = left

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# Typography
font-size = 15
font-family = "JetBrainsMono Nerd Font Mono"
font-style = "Medium"
font-style-bold = "Bold"
font-style-italic = "Medium Italic"
font-style-bold-italic = "Bold Italic"
adjust-cell-height = 10%
adjust-cell-width = 2%
alpha-blending = linear
theme = flume

# Font quality and thickness adjustments for macOS
font-thicken = true
font-thicken-strength = 140

# Cursor
cursor-style = block
cursor-opacity = 0.96

# Tmux keybindings (\x01 = ctrl-a)
# Search in pane
keybind = cmd+/=text:\x01\x06
# Windows navigation
keybind = cmd+physical:one=text:\x01\x31
keybind = cmd+physical:two=text:\x01\x32
keybind = cmd+physical:three=text:\x01\x33
keybind = cmd+physical:four=text:\x01\x34
keybind = cmd+physical:five=text:\x01\x35
keybind = cmd+physical:six=text:\x01\x36
keybind = cmd+physical:seven=text:\x01\x37
keybind = cmd+physical:eight=text:\x01\x38
keybind = cmd+physical:nine=text:\x01\x39

# Vim keybindings
# Select all (ggVG)
keybind = cmd+a=text:\x1bggVG
