title = "Ghostty"
macos-window-shadow = true
# window-title-font-family = "JetBrainsMono Nerd Font Mono"

window-padding-x = 3
window-padding-y = 3
window-padding-balance = true

command = /opt/homebrew/bin/fish
shell-integration = fish

clipboard-read = allow
clipboard-write = allow
confirm-close-surface = false
macos-option-as-alt = left

font-size = 16
font-family = "JetBrainsMono Nerd Font Mono"
font-style = "Medium"
font-style-bold = "Bold"
font-style-italic = "Medium Italic"
font-style-bold-italic = "Bold Italic"
adjust-cell-height = 12%
alpha-blending = linear
theme = duskfox
# font-feature = -calt
# font-feature = -liga
# font-feature = -dlig

cursor-style = block
cursor-opacity=0.96

# tmux (\x01 = ctrl-a)
# search in pane
keybind = cmd+/=text:\x01\x06
# windows
keybind = cmd+physical:one=text:\x01\x31
keybind = cmd+physical:two=text:\x01\x32
keybind = cmd+physical:three=text:\x01\x33
keybind = cmd+physical:four=text:\x01\x34
keybind = cmd+physical:five=text:\x01\x35
keybind = cmd+physical:six=text:\x01\x36
keybind = cmd+physical:seven=text:\x01\x37
keybind = cmd+physical:eight=text:\x01\x38
keybind = cmd+physical:nine=text:\x01\x39

# vim: ft=conf
# vim bindings example (select all)
keybind = cmd+a=text:\x1bggVG
